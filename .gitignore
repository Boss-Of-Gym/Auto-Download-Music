# Virtual environment
.venv/

# PyInstaller build outputs
dist/
build/

# Python cache
__pycache__/
*.pyc
*.pyo

# Playwright browsers (downloaded automatically on first run)
browsers/

# Track progress files (user data, generated at runtime)
*_tracks.json

# Claude Code session data
.claude/

# User-local GUI settings (window geometry, etc.)
gui_settings.json

# Logs
*.log
